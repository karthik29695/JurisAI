# ─────────────────────────────────────────────────────────────────────────────
#  JurisAI  —  Environment Configuration Template
#  Copy this file to .env and fill in your values.
#  NEVER commit the real .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Flask ─────────────────────────────────────────────────────────────────────
# A long random string used to sign session cookies.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=your-long-random-secret-key-here
FLASK_ENV=development

# ── Gemini API ────────────────────────────────────────────────────────────────
# Primary API key (from https://aistudio.google.com)
GOOGLE_API_KEY=your-gemini-api-key-here

# Optional: comma-separated pool of keys for automatic rotation under load
# GEMINI_API_KEYS=key1,key2,key3

# Model names (defaults shown — change only if needed)
# CHAT_MODEL=gemini-2.5-flash
# EMBED_MODEL=models/embedding-001

# Set to "true" to use Gemini for embeddings instead of the local model
# USE_GEMINI_EMBEDDINGS=false

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local development default — change for production (e.g. Redis Cloud URL)
REDIS_URL=redis://localhost:6379/0

# How long a session stays alive after the last request, in seconds (default 30 min)
# SESSION_TTL_SECONDS=1800

# ── Local Embedding Model ─────────────────────────────────────────────────────
# SentenceTransformer model name (downloaded automatically on first run)
# LOCAL_EMBED_MODEL=all-MiniLM-L6-v2

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for cross-origin requests.
# Leave empty to allow all origins (development only).
# ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:5000

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
